# Mealie-AI-Tools configuration.
#
# Copy this file to ~/.config/Mealie-AI-Tools/.env (the default location),
# or to ./.env in your working directory, or point at it with --env-file.
# Fill in your own values below. NEVER commit a real .env — it holds live
# credentials.

# --- Required ---

# Base URL of your Mealie instance (no trailing slash needed).
# Example: https://mealie.example.com
MEALIE_URL=

# A Mealie API token (Mealie: Settings -> API Tokens).
MEALIE_API_TOKEN=

# Google AI (Gemini) API key, used for recipe text and image generation.
# Get one at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# --- Optional overrides (uncomment to change the defaults) ---

# UI and recipe language: "no" (default) or "en".
#MEALIE_LANG=no

# Gemini model overrides.
#GEMINI_TEXT_MODEL=gemini-2.5-flash
#GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Gemini request timeout in whole seconds (defaults: 120 text, 300 image).
# Raise it on slow links or for large images.
#GEMINI_TIMEOUT=300

# Allow a plain http:// MEALIE_URL (token sent in cleartext). Off by default;
# set to 1 only for a trusted LAN-only Mealie.
#MEALIE_ALLOW_HTTP=1
